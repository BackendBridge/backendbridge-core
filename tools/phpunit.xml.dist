<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="vendor/autoload.php" colors="true" cacheResult="false">
  <testsuites>
    <testsuite name="BackendBridge Tools Tests">
      <directory>tests</directory>
    </testsuite>
  </testsuites>
  <php>
    <env name="BACKENDBRIDGE_GENERATED_ROOT" value="./ci-out" />
  </php>
</phpunit>